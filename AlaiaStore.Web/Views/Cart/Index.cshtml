@model AlaiaStore.Domain.Entities.Cart

@{
    ViewData["Title"] = "Mi Carrito";
    decimal total = Model?.Items?.Sum(i => i.Quantity * i.UnitPrice) ?? 0;
}

<div class="container my-5">
    <h2 class="mb-4">Mi Carrito de Compras</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model == null || !Model.Items.Any())
    {
        <div class="alert alert-info">
            Tu carrito está vacío. <a href="@Url.Action("Index", "Product")" class="alert-link">¡Sigue comprando!</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th scope="col">Producto</th>
                        <th scope="col">Precio</th>
                        <th scope="col">Cantidad</th>
                        <th scope="col">Subtotal</th>
                        <th scope="col"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <strong>@item.Product.Name</strong>
                            </td>
                            <td>@item.UnitPrice.ToString("C")</td>
                            <td>
                                <form asp-action="UpdateQuantity" method="post" class="d-inline-flex align-items-center">
                                    <input type="hidden" name="itemId" value="@item.Id" />
                                    <input type="number" name="quantity" value="@item.Quantity" class="form-control form-control-sm me-2" style="width: 70px;" min="1" max="99" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Actualizar cantidad">
                                        <i class="bi bi-arrow-repeat"></i>
                                    </button>
                                </form>
                            </td>
                            <td>@((item.Quantity * item.UnitPrice).ToString("C"))</td>
                            <td>
                                <form asp-action="Remove" method="post" class="d-inline">
                                    <input type="hidden" name="itemId" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end"><strong>Total:</strong></td>
                        <td colspan="2"><strong>@total.ToString("C")</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="d-flex justify-content-end mt-4">
            <a href="@Url.Action("Index", "Product")" class="btn btn-outline-secondary me-2">Seguir Comprando</a>
            <button class="btn btn-primary" onclick="alert('Funcionalidad de pago no implementada aún.')">Proceder al Pago</button>
        </div>
    }
</div>
