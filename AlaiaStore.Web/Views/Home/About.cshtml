@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5 mt-5">
    <div class="row align-items-center">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <img src="~/images/about_logo.png" alt="About GlowSkin" class="img-fluid rounded shadow-sm" />
        </div>
        <div class="col-lg-6 px-lg-5">
            <h1 class="display-4 font-title mb-4">Our Story</h1>
            <p class="lead text-muted mb-4">
                At GlowSkin Store, we believe that skincare should be a luxurious, simple, and effective experience.
                We are dedicated to providing premium skincare products with pure ingredients that enhance your natural
                beauty.
            </p>
            <p class="body-medium text-muted mb-4">
                Founded with the vision of offering high-quality dermatological solutions, our curated selection of
                products
                is designed to nourish, protect, and revitalize every skin type. We meticulously choose each ingredient
                to ensure you receive the safest and most effective care.
            </p>
            <div class="d-flex align-items-center mb-4">
                <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
                <span class="fs-5">Cruelty-Free & Vegan</span>
            </div>
            <div class="d-flex align-items-center mb-4">
                <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
                <span class="fs-5">Dermatologically Tested</span>
            </div>
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
                <span class="fs-5">Sustainable Packaging</span>
            </div>
        </div>
    </div>
</div>
