@model IEnumerable<AlaiaStore.Web.ViewModels.Blog.BlogPostListItemViewModel>
@{
    ViewData["Title"] = "Blog";
}

<div class="container my-5 pt-4">
    <div class="mb-4">
        <h1 class="headline-large mb-1">GlowSkin Journal</h1>
        <p class="body-medium text-muted">Consejos, tendencias y cuidado de la piel</p>
    </div>

    <div class="row g-4">
        @foreach (var post in Model)
        {
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="overflow-hidden" style="height: 220px; background-color: var(--color-surface);">
                        @if (!string.IsNullOrWhiteSpace(post.ImageUrl))
                        {
                            <img src="@post.ImageUrl" class="w-100 h-100 object-fit-cover" alt="@post.Title" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100">
                                <i class="bi bi-image text-muted" style="font-size: 2rem;"></i>
                            </div>
                        }
                    </div>
                    <div class="card-body">
                        <h5 class="font-title mb-2">@post.Title</h5>
                        <p class="body-medium text-muted">@post.Summary</p>
                        <a asp-controller="Blog" asp-action="Details" asp-route-id="@post.Id" class="btn btn-outline-secondary w-100">Leer más</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center mt-5">
            <p class="body-large text-muted">No hay publicaciones disponibles todavía.</p>
        </div>
    }
</div>
