@model IEnumerable<AlaiaStore.Web.ViewModels.Blog.BlogPostListItemViewModel>
@{
    ViewData["Title"] = "Blog Admin";
}

<div class="container my-5 pt-4">
    <partial name="_AdminNav" />
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h1 class="headline-large mb-1">Blog</h1>
            <p class="body-medium text-muted">Gestión de contenido</p>
        </div>
        <a class="btn btn-primary" asp-action="Create">Nueva publicación</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-borderless align-middle mb-0">
                <thead class="border-bottom">
                    <tr>
                        <th>Título</th>
                        <th>Fecha</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in Model)
                    {
                        <tr>
                            <td>@post.Title</td>
                            <td>@post.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-dark" asp-action="Edit" asp-route-id="@post.Id">Editar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
