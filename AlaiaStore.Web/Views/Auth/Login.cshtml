@model AlaiaStore.Web.DTOs.LoginDto
@{
    ViewData["Title"] = "Sign In";
}

<div class="container mt-5 pt-4">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="text-center mb-5">
                <h1 class="headline-large">Welcome Back</h1>
                <p class="body-medium text-muted">Sign in to your GlowSkin Store account</p>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form method="post" asp-action="Login">
                <div class="mb-4">
                    <label asp-for="Email" class="form-label body-medium">Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="your@email.com" required />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label body-medium">Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="alert alert-danger" role="alert">
                        <div asp-validation-summary="All" class="text-danger mb-0"></div>
                    </div>
                }

                <button type="submit" class="btn btn-primary w-100 py-2 mb-3">Sign In</button>

                <div class="text-center">
                    <p class="body-medium text-muted">
                        Don't have an account?
                        <a asp-action="Register" class="text-dark text-decoration-none fw-bold">Create one</a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>
