<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GlowSkin Store</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AlaiaStore.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light sticky-top border-bottom">
            <div class="container-fluid px-4">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">GlowSkin Store</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav mx-auto flex-grow-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Product" asp-action="Index">Skincare</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Product" asp-action="BestSellers">Best Sellers</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Blog" asp-action="Index">Blog</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="About">About</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <form class="d-flex" asp-controller="Product" asp-action="Search" method="get">
                                <div class="input-group input-group-sm">
                                    <input type="text" name="query" class="form-control" placeholder="Buscar" aria-label="Buscar">
                                    <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
                                </div>
                            </form>
                        </li>
                        <li class="nav-item">
                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                <div class="nav-link dropdown">
                                    <a href="#" class="text-decoration-none text-dark" data-bs-toggle="dropdown">
                                        <i class="bi bi-person-check"></i>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index">Mi Perfil</a></li>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">Panel Admin</a></li>
                                            <li><a class="dropdown-item" asp-controller="Promotion" asp-action="Index">Promociones</a></li>
                                            <li><a class="dropdown-item" asp-controller="Blog" asp-action="Admin">Blog Admin</a></li>
                                        }
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form method="post" asp-action="Logout" asp-controller="Auth">
                                                <button type="submit" class="dropdown-item">Cerrar Sesi�n</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            }
                            else
                            {
                                <a class="nav-link" asp-controller="Auth" asp-action="Login"><i class="bi bi-person"></i></a>
                            }
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cart" asp-action="Index"><i class="bi bi-cart3"></i></a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-5">
        @RenderBody()
    </main>

    <footer class="border-top py-4 mt-5">
        <div class="container text-center">
            <h5 class="font-title mb-3">GlowSkin Store</h5>
            <p class="body-medium text-muted">Premium Skincare. Minimal Luxury. Pure Ingredients.</p>
            <div class="mt-3">
                &copy; @DateTime.Now.Year - AlaiaStore - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none">Privacy</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>