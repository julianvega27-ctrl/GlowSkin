@model AlaiaStore.Web.ViewModels.ProductCatalogViewModel
@{
    ViewData["Title"] = "Skincare Collection";
}

<div class="container mt-5 pt-4">
    <div class="text-center mb-5">
        <h1 class="headline-large">Skincare Collection</h1>
        <p class="body-large text-muted">Pure ingredients for your natural radiance.</p>
    </div>

    <div class="row">
        <!-- Sidebar Categorías -->
        <div class="col-md-3 mb-4">
            <h5 class="font-title mb-3">Categories</h5>
            <ul class="list-group list-group-flush border-0">
                <li class="list-group-item border-0 px-0">
                    <a asp-action="Index" asp-route-categoryId="" class="text-decoration-none @(Model.SelectedCategoryId == null ? "text-dark fw-bold" : "text-muted")">All Products</a>
                </li>
                @foreach (var category in Model.Categories)
                {
                    <li class="list-group-item border-0 px-0">
                        <a asp-action="Index" asp-route-categoryId="@category.Id" class="text-decoration-none @(Model.SelectedCategoryId == category.Id ? "text-dark fw-bold" : "text-muted")">
                            @category.Name
                        </a>
                    </li>
                }
            </ul>
        </div>

        <!-- Product Grid -->
        <div class="col-md-9">
            <div class="row g-4">
                @if (Model.Products != null && Model.Products.Any())
                {
                    foreach (var product in Model.Products)
                    {
                        <div class="col-md-4 col-sm-6">
                            <div class="card h-100">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none">
                                    <div class="card-img-top d-flex align-items-center justify-content-center overflow-hidden" style="height: 300px;">
                                        @if(!string.IsNullOrEmpty(product.MainImageUrl)) {
                                            <img src="@product.MainImageUrl" alt="@product.Name" class="w-100 h-100 object-fit-cover" />
                                        } else {
                                            <i class="bi bi-stars text-muted" style="font-size: 3rem;"></i>
                                        }
                                    </div>
                                </a>
                                <div class="card-body text-center mt-3 p-0">
                                    <p class="body-medium text-muted mb-0" style="font-size: 0.85rem; text-transform: uppercase;">@product.CategoryName</p>
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="text-decoration-none text-dark">
                                        <h5 class="font-title mb-1">@product.Name</h5>
                                    </a>
                                    <p class="body-medium text-muted mb-2">$@product.Price.ToString("F2")</p>
                                    <a href="#" class="btn btn-secondary w-100 mt-2">Add to Bag</a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <p class="body-large text-muted">No products found in this category.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>