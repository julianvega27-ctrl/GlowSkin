@model AlaiaStore.Web.ViewModels.Admin.AdminOrderListViewModel
@{
    ViewData["Title"] = "Pedidos";
}

<div class="container my-5 pt-4">
    <partial name="_AdminNav" />
    <div class="mb-4">
        <h1 class="headline-large mb-1">Pedidos</h1>
        <p class="body-medium text-muted">Listado de pedidos recientes</p>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-borderless align-middle mb-0">
                <thead class="border-bottom">
                    <tr>
                        <th>#</th>
                        <th>Cliente</th>
                        <th class="text-end">Total</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Pago</th>
                        <th class="text-end">Fecha</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        <tr>
                            <td>#@order.Id</td>
                            <td>@order.CustomerName</td>
                            <td class="text-end">$@order.TotalAmount.ToString("F2")</td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark">@order.Status</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark">@order.PaymentStatus</span>
                            </td>
                            <td class="text-end">@order.CreatedAt.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
