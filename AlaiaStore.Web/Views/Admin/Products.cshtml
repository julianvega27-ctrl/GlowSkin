@model AlaiaStore.Web.ViewModels.Admin.AdminProductListViewModel
@{
    ViewData["Title"] = "Gestión de productos";
}

<div class="container my-5 pt-4">
    <partial name="_AdminNav" />
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h1 class="headline-large mb-1">Productos</h1>
            <p class="body-medium text-muted">Administración del catálogo</p>
        </div>
        <a class="btn btn-primary px-4" asp-action="CreateProduct">Nuevo producto</a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Categoría</label>
                    <select class="form-select" name="categoryId">
                        <option value="">Todas</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.Id" selected="@(Model.SelectedCategoryId == category.Id)">@category.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-outline-secondary">Filtrar</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-borderless align-middle mb-0">
                <thead class="border-bottom">
                    <tr>
                        <th>Producto</th>
                        <th>Categoría</th>
                        <th class="text-end">Precio</th>
                        <th class="text-center">Stock</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.Products)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@product.Name</div>
                                <small class="text-muted">#@product.Id</small>
                            </td>
                            <td>@product.CategoryName</td>
                            <td class="text-end">$@product.Price.ToString("F2")</td>
                            <td class="text-center">@product.Stock</td>
                            <td class="text-center">
                                <span class="badge @(product.IsActive ? "bg-success" : "bg-secondary")">@(product.IsActive ? "Activo" : "Inactivo")</span>
                            </td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-dark" asp-action="EditProduct" asp-route-id="@product.Id">Editar</a>
                                <form method="post" asp-action="ToggleProductStatus" asp-route-id="@product.Id" class="d-inline">
                                    <button class="btn btn-sm btn-outline-secondary">@(product.IsActive ? "Desactivar" : "Activar")</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
