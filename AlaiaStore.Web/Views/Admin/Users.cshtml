@model AlaiaStore.Web.ViewModels.Admin.AdminUserListViewModel
@{
    ViewData["Title"] = "Usuarios";
}

<div class="container my-5 pt-4">
    <partial name="_AdminNav" />
    <div class="mb-4">
        <h1 class="headline-large mb-1">Usuarios</h1>
        <p class="body-medium text-muted">Listado de usuarios registrados</p>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-borderless align-middle mb-0">
                <thead class="border-bottom">
                    <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th class="text-center">Estado</th>
                        <th class="text-end">Registro</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>#@user.Id</td>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td class="text-center">
                                <span class="badge @(user.IsActive ? "bg-success" : "bg-secondary")">@(user.IsActive ? "Activo" : "Inactivo")</span>
                            </td>
                            <td class="text-end">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
