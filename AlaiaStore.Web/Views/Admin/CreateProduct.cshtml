@model AlaiaStore.Web.ViewModels.Admin.AdminProductFormViewModel
@{
    ViewData["Title"] = "Nuevo producto";
}

<div class="container my-5 pt-4">
    <partial name="_AdminNav" />
    <div class="mb-4">
        <h1 class="headline-large mb-1">Nuevo producto</h1>
        <p class="body-medium text-muted">Completa la información del producto</p>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <form method="post" enctype="multipart/form-data">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Nombre</label>
                        <input asp-for="Product.Name" class="form-control" />
                        <span asp-validation-for="Product.Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Categoría</label>
                        <select asp-for="Product.CategoryId" class="form-select">
                            <option value="">Selecciona</option>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </select>
                        <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Precio</label>
                        <input asp-for="Product.Price" class="form-control" />
                        <span asp-validation-for="Product.Price" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Stock</label>
                        <input asp-for="Product.Stock" class="form-control" />
                        <span asp-validation-for="Product.Stock" class="text-danger"></span>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Subir Imagen</label>
                        <input asp-for="Product.ImageFile" type="file" class="form-control" accept="image/*" />
                        <span asp-validation-for="Product.ImageFile" class="text-danger"></span>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Descripción</label>
                        <textarea asp-for="Product.Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Ingredientes</label>
                        <textarea asp-for="Product.Ingredients" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Skin Type</label>
                        <textarea asp-for="Product.SkinType" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Activo</label>
                        <div class="form-check">
                            <input asp-for="Product.IsActive" class="form-check-input" />
                            <label class="form-check-label" for="Product_IsActive">Visible</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Destacado</label>
                        <div class="form-check">
                            <input asp-for="Product.IsBestSeller" class="form-check-input" />
                            <label class="form-check-label" for="Product_IsBestSeller">Best Seller</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a class="btn btn-outline-secondary" asp-action="Products">Cancelar</a>
                    <button class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>
